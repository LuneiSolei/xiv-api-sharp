{
    "TestingOptions": {
        "ClauseTests": {
            "CreateClauseTest": {
                "Decorator": "MustNot",
                "Specifier": "Name",
                "Language": "EN",
                "Operator": "PartiallyEqual",
                "Value": "Phantom",
                "ExpectedValue": "-Name@en~\"Phantom\""
            },
            "ToUriEncodedStringTest": {
                "Decorator": "Must",
                "Specifier": "Amount",
                "Language": "EN",
                "Operator": "Equal",
                "Value": 42,
                "ExpectedValue": "%2BAmount%40en%3D42"
            },
            "ClauseGroupAddClauseTest": {
                "Decorator": "MustNot",
                "Specifier": "Name",
                "Language": "EN",
                "Operator": "PartiallyEqual",
                "Value": "Curtana",
                "ExpectedValue": "(-Name@en~\"Curtana\")"
            },
            "ClauseGroupAddClausesTest": {
                "FirstClause": {
                    "Decorator": "MustNot",
                    "Specifier": "SomeRandomField",
                    "Language": "JA",
                    "Operator": "Equal",
                    "Value": "This weird value",
                    "ExpectedValue": ""
                },
                "SecondClause": {
                    "Decorator": "Must",
                    "Specifier": "Books",
                    "Language": "DE",
                    "Operator": "LessThanOrEqual",
                    "Value": 2500,
                    "ExpectedValue": ""
                },
                "ThirdClause": {
                    "Decorator": "Must",
                    "Specifier": "Mogtomes",
                    "Language": "FR",
                    "Operator": "LessThan",
                    "Value": 250.0,
                    "ExpectedValue": ""
                },
                "Decorator": "None",
                "ExpectedValue": "%28-SomeRandomField%40ja%3D%22This+weird+value%22 %2BBooks%40de%3C%3D2500 %2BMogtomes%40fr%3C250%29"
            }
        },
        "XivApiServiceTests": {
            "NewClauseTest": {
                "Decorator": "Must",
                "Specifier": "Amount",
                "Language": "EN",
                "Operator": "GreaterThanOrEqual",
                "Value": 27,
                "ExpectedValue": "%2BAmount%40en%3D27"
            },
            "NewClauseGroupTest": {
                "FirstClause": {
                    "Decorator": "MustNot",
                    "Specifier": "SomeRandomField",
                    "Language": "JA",
                    "Operator": "Equal",
                    "Value": "This weird value",
                    "ExpectedValue": ""
                },
                "SecondClause": {
                    "Decorator": "Must",
                    "Specifier": "Amount",
                    "Language": "DE",
                    "Operator": "LessThanOrEqual",
                    "Value": 60,
                    "ExpectedValue": ""
                },
                "ThirdClause": {
                    "Decorator": "None",
                    "Specifier": "Gil",
                    "Language": "FR",
                    "Operator": "LessThan",
                    "Value": 7.5,
                    "ExpectedValue": ""
                },
                "Decorator": "MustNot",
                "UnencodedClauses": "-SomeRandomField@ja=\"This weird value\" +Amount@de<=60.2983 Gil@fr<7.5",
                "ExpectedValue": "-%28-SomeRandomField%40ja%3D%22This+weird+value%22 %2BAmount%40de%3C%3D60 Gil%40fr%3C7.5%29"
              }
        },
        "QueryStringTests": {
