{
    "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
    "metadata": [
        {
            "src": [
                {
                    "src": "./",
                    "files": [
                        "**/*.csproj"
                    ],
                    "exclude": [
                        "docs/**"
                    ]
                }
            ],
            "dest": "docs/api"
        }
    ],
    "build": {
        "markdownEngineProperties": {
            "alerts": {
                "TODO": "alert alert-secondary",
                "DEV_NOTE": "alert alert-secondary"
            }
        },
        "content": [
            {
                "src": "docs",
                "files": [
                    "**/*.{md,yml}"
                ],
                "exclude": [
                    "_site/**"
                ]
            }
        ],
        "resource": [
            {
                "files": [
                    "docs/images/**"
                ]
            }
        ],
        "output": "docs/_site",
        "template": [
            "default",
            "modern",
            "docs/templates/custom-alert-titles"
        ],
        "globalMetadata": {
            "_appName": "XIV API Sharp",
            "_appTitle": "XIV API Sharp",
            "_enableSearch": false,
            "pdf": false
        }
    }
}